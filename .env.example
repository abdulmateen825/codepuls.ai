# CodePulse AI environment example
# Copy to .env for Docker Compose or source values manually for local services.
# Never commit real secrets.

###############################################################################
# Shared
###############################################################################
APP_ENV=local
LOG_LEVEL=INFO
OPEN_SOURCE_MODE=true
ENFORCE_USAGE_LIMITS=false
INTERNAL_API_KEY=change-me-use-a-long-random-value

###############################################################################
# Frontend
###############################################################################
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080
CORE_API_BASE_URL=http://localhost:8080

###############################################################################
# Spring Boot backend-core
###############################################################################
SERVER_PORT=8080
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/codepulse
SPRING_DATASOURCE_USERNAME=codepulse
SPRING_DATASOURCE_PASSWORD=change-me-local-db-password
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_SHOW_SQL=false
JWT_SECRET=change-me-use-at-least-32-random-characters
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000
FASTAPI_BASE_URL=http://localhost:8000
FRONTEND_ALLOWED_ORIGINS=http://localhost:3000
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MAX_SCANS_PER_USER=0
MAX_CONCURRENT_SCANS=0
REPORT_STORAGE_MODE=database
REPORT_STORAGE_PATH=/var/lib/codepulse/reports

###############################################################################
# FastAPI backend-ai
###############################################################################
FASTAPI_PORT=8000
SPRING_BOOT_BASE_URL=http://localhost:8080
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION=codepulse_chunks
LLM_PROVIDER=fallback
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_VECTOR_SIZE=384
REPOSITORY_CLONE_TIMEOUT_SECONDS=180
MAX_REPOSITORY_SIZE_MB=0
MAX_FILE_COUNT=5000
MAX_INDIVIDUAL_FILE_SIZE_BYTES=1000000
MAX_SCAN_TIME_SECONDS=0
CODEPULSE_WORKSPACE_ROOT=/tmp/codepulse
REPORT_PATH=/tmp/codepulse-reports
SCANNER_TIMEOUT_SECONDS=120
GIT_PATH=git
SEMGREP_PATH=semgrep
BANDIT_PATH=bandit
RUFF_PATH=ruff
GITLEAKS_PATH=gitleaks
NPX_PATH=npx

###############################################################################
# Code-smell thresholds
###############################################################################
CODE_SMELL_MAX_METHOD_LINES=50
CODE_SMELL_MAX_CLASS_LINES=300
CODE_SMELL_MAX_COMPLEXITY=10
CODE_SMELL_MAX_NESTING_DEPTH=4
CODE_SMELL_MAX_PARAMETER_COUNT=5
CODE_SMELL_MIN_DUPLICATE_LINES=8
CODE_SMELL_GOD_OBJECT_MIN_METHODS=20
CODE_SMELL_GOD_OBJECT_MIN_FIELDS=15
CODE_SMELL_MAX_SNIPPET_LINES=120
CODE_SMELL_CONTEXT_LINES=5
CODE_SMELL_MAX_FILE_BYTES=1000000
CODE_SMELL_MAX_SOURCE_CHARS=20000

###############################################################################
# Local Docker infrastructure
###############################################################################
POSTGRES_DB=codepulse
POSTGRES_USER=codepulse
POSTGRES_PASSWORD=change-me-local-db-password
REDIS_PASSWORD=
